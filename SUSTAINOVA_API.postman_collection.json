{
    "info": {
        "name": "SUSTAINOVA API",
        "description": "Complete API collection for SUSTAINOVA Smart Office PWA backend",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:5000/api",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "🔑 Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Varun Rahatgaonkar\",\n  \"email\": \"varun@sustainova.in\",\n  \"password\": \"test1234\",\n  \"role\": \"employee\",\n  \"department\": \"IT Engineering\",\n  \"floor\": 12\n}"
                        }
                    }
                },
                {
                    "name": "Register Admin",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Aditya Mitra\",\n  \"email\": \"admin@sustainova.in\",\n  \"password\": \"admin1234\",\n  \"role\": \"admin\",\n  \"department\": \"Administration\",\n  \"floor\": 15\n}"
                        }
                    }
                },
                {
                    "name": "Register Maintenance",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Rajan Sharma\",\n  \"email\": \"maintenance@sustainova.in\",\n  \"password\": \"maint1234\",\n  \"role\": \"maintenance\",\n  \"department\": \"Facilities\",\n  \"floor\": 0\n}"
                        }
                    }
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const r = pm.response.json();",
                                    "if (r.token) pm.collectionVariables.set('token', r.token);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"varun@sustainova.in\",\n  \"password\": \"test1234\"\n}"
                        }
                    }
                },
                {
                    "name": "Login as Admin",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const r = pm.response.json();",
                                    "if (r.token) pm.collectionVariables.set('token', r.token);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@sustainova.in\",\n  \"password\": \"admin1234\"\n}"
                        }
                    }
                },
                {
                    "name": "Get Me",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/auth/me",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/logout",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "👥 Users (Admin)",
            "item": [
                {
                    "name": "Get All Users",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/users",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Search Users",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/users?search=varun",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Filter by Role",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/users?role=maintenance",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "🎫 Tickets",
            "item": [
                {
                    "name": "Create Ticket",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/tickets",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"AC not cooling in Meeting Room 3B\",\n  \"description\": \"The split AC on floor 8 room 3B has been blowing warm air since morning. Temperature inside is 28°C.\",\n  \"category\": \"facilities\",\n  \"priority\": \"high\",\n  \"location\": \"Floor 8, Meeting Room 3B\"\n}"
                        }
                    }
                },
                {
                    "name": "Create IT Ticket",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/tickets",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"WiFi dropping on Floor 12\",\n  \"description\": \"WiFi connection drops every 10 minutes on floor 12 east wing. Happens on all devices.\",\n  \"category\": \"it\",\n  \"priority\": \"medium\",\n  \"location\": \"Floor 12, East Wing\"\n}"
                        }
                    }
                },
                {
                    "name": "Get My Tickets",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/tickets",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Get Ticket Stats (Admin)",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/tickets/stats",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Filter Tickets by Status",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/tickets?status=open",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Update Ticket (Admin)",
                    "request": {
                        "method": "PUT",
                        "url": "{{base_url}}/tickets/TICKET_ID_HERE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"in_progress\",\n  \"notes\": \"Tech team dispatched to investigate\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "🚗 Parking",
            "item": [
                {
                    "name": "Seed Parking Data (Admin - run once)",
                    "request": {
                        "method": "POST",
