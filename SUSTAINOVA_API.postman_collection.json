                {
                    "name": "Free a Slot",
                    "request": {
                        "method": "DELETE",
                        "url": "{{base_url}}/parking/B1-A5/reserve",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                }
            ]
