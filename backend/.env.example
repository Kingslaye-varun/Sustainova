PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/sustainova

# JWT
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# Gemini AI (Google) — for NOVA health assistant chatbot
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (comma-separated for multiple origins)
CLIENT_URL=http://localhost:5173

# Cloudinary — for staff photos & QR code uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (NodeMailer) — use Gmail App Password, not your real password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=noreply@sustainova.in
